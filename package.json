{
  "name": "fm-jsdriver",
  "version": "1.0.1",
  "description": "Type-safe FileMaker driver for webviewer communication using fm-gofer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "fm-generate-schema": "dist/generator.js"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "generate-schema": "node dist/generator.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "filemaker",
    "driver",
    "webviewer",
    "typescript",
    "fm-gofer",
    "data-api",
    "database",
    "type-safe"
  ],
  "author": "Stathis Askaridis <sa@pineapple.gr>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "fm-gofer": "file:../fm-gofer",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pineapplegr/fm-jsDriver.git"
  }
}
